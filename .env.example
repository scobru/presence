# Segreto per la firma dei JWT e dei cookie di sessione di Indiekit.
# Sostituisci con una stringa lunga e casuale.
INDIEAUTH_SECRET=genera_una_stringa_casuale_e_lunga_qui

# L'hash crittografato della tua password per accedere ad Indiekit.
# Come generarlo:
# 1. Avvia i container e visita la pagina del tuo server Indiekit all'indirizzo `/auth/new-password`
# 2. Inserisci la tua password in chiaro e clicca su "Generate password secret"
# 3. Copia il codice generato (una stringa molto lunga) e incollalo qui sotto
INDIEAUTH_PASSWORD_SECRET=incolla_qui_il_segreto_della_password_generato_da_indiekit

# L'URL pubblico della tua istanza di Indiekit (usato dal blog frontend per mostrare gli URL corretti degli endpoint).
# Es: http://[IP_DELLA_VPS]:3001 oppure https://presence.scobru.it se usi un reverse proxy
INDIEKIT_PUBLIC_URL=http://localhost:3001

# Integrazione Mastodon (Crossposting)
# 1. Crea un'applicazione su Mastodon (Preferenze -> Sviluppo -> Nuova applicazione) con i permessi "write".
# 2. Copia l'Access Token generato ed incollalo qui sotto.
MASTODON_URL=https://livellosegreto.it
MASTODON_USER=@scobru
MASTODON_ACCESS_TOKEN=il_tuo_mastodon_access_token_qui
