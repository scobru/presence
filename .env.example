# Identità pubblica del sito (valore `me` di IndieAuth).
# Deve combaciare ESATTAMENTE con l'URL pubblico (senza slash finale).
ME=https://presence.scobrudot.dev

# Segreto per firmare gli access token IndieAuth. Stringa lunga e casuale.
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=genera_una_stringa_casuale_e_lunga_qui

# Password unica usata sia per la UI /admin sia per autorizzare i client
# Micropub via IndieAuth. Senza questa, /admin e /micropub restano disabilitati.
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_questa_password

# In alternativa a ADMIN_PASSWORD in chiaro, puoi usare un hash (ha la precedenza se presente):
# 1. Avvia il server e visita `/auth/new-password`
# 2. Inserisci la password in chiaro e genera l'hash
# 3. Incolla il risultato qui sotto e rimuovi ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=scrypt:...

# Syndication Mastodon (opzionale): crosspost automatico a ogni nuovo post.
# Attiva solo se MASTODON_URL e MASTODON_ACCESS_TOKEN sono entrambe presenti.
# Crea un'app su Mastodon (Preferenze -> Sviluppo) con permesso "write:statuses".
MASTODON_URL=https://livellosegreto.it
MASTODON_USER=@scobru
MASTODON_ACCESS_TOKEN=il_tuo_mastodon_access_token_qui
