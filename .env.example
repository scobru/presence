# Public identity of the site (IndieAuth `me` value).
# Must match the public URL EXACTLY (no trailing slash).
ME=https://presence.scobrudot.dev

# Secret for signing IndieAuth access tokens. Long, random string.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=generate_a_long_random_string_here

# Single password used both for the /admin UI and to authorize Micropub
# clients via IndieAuth. Without this, /admin and /micropub stay disabled.
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_password

# As an alternative to plaintext ADMIN_PASSWORD, you can use a hash (takes precedence if present):
# 1. Start the server and visit `/auth/new-password`
# 2. Enter the plaintext password and generate the hash
# 3. Paste the result below and remove ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=scrypt:...

# Mastodon syndication (optional): automatic crosspost on every new post.
# Active only if MASTODON_URL and MASTODON_ACCESS_TOKEN are both present.
# Create an app on Mastodon (Preferences -> Development) with "write:statuses" permission.
MASTODON_URL=https://livellosegreto.it
MASTODON_USER=@scobru
MASTODON_ACCESS_TOKEN=your_mastodon_access_token_here
